&lt;li&gt;&lt;a href=&quot;https:&#x2F;&#x2F;rust-lang.github.io&#x2F;rfcs&#x2F;0387-higher-ranked-trait-bounds.html&quot;&gt;https:&#x2F;&#x2F;rust-lang.github.io&#x2F;rfcs&#x2F;0387-higher-ranked-trait-bounds.html&lt;&#x2F;a&gt;&lt;&#x2F;li&gt;
&lt;li&gt;&lt;a href=&quot;https:&#x2F;&#x2F;www.rustfinity.com&#x2F;blog&#x2F;higher-rank-trait-bounds&quot;&gt;https:&#x2F;&#x2F;www.rustfinity.com&#x2F;blog&#x2F;higher-rank-trait-bounds&lt;&#x2F;a&gt;&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
</content>
        
